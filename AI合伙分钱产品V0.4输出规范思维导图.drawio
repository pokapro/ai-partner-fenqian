        <mxCell id="contract_h" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;arcSize=8;" value="三、合同格式规范" vertex="1">
