        <mxCell id="rights_b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#86EFAC;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=16;arcSize=6;" value="所有权：谁持股、谁登记、是否代持&#xa;分红权：利润如何分，是否等同股权&#xa;经营权：谁负责日常经营和岗位职责&#xa;决策权：一般事项和重大事项谁拍板&#xa;退出权：主动、被动、法定退出如何处理&#xa;&#xa;要求：必须区分“股权比例”和“实际控制/经营/分红安排”。" vertex="1">
          <mxGeometry height="210" width="1400" x="1100" y="400" as="geometry" />
