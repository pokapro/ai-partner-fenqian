          <mxGeometry height="70" width="360" x="690" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="clauses_b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2F8;strokeColor=#F9A8D4;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=16;arcSize=6;" value="基础必出：分红条款、职责条款、亏损承担、账目公开、退出条款、沟通话术&#xa;&#xa;进阶触发：代持协议提示、重大事项表决、任职股东考核、红线行为、竞业限制、增资入股、清算终止&#xa;&#xa;要求：每条包含触发条件、执行方式、后果。" vertex="1">
