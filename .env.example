# AI 合伙分钱 V0 - 环境变量

# 服务端口
PORT=3000

# AI API 供应商：glm | qwen | deepseek | ollama
AI_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM Flash
GLM_API_KEY=
GLM_MODEL=glm-4-flash

# 通义千问
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo

# Ollama 本地
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
